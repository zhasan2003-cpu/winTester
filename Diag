function Collect-Drivers {
    Write-Host "Collecting drivers..."

    $out = Join-Path $Script:ReportsPath "08_Drivers.txt"

    try {
        Append-Text $out "=== WIN32 SYSTEM DRIVERS ==="
        $drivers = Get-CimSafe -ClassName Win32_SystemDriver
        Export-Object $drivers $out (Join-Path $Script:CsvPath "Drivers_System.csv")

        Append-Text $out "`r`n=== PNP SIGNED DRIVERS ==="
        $signed = Get-CimSafe -ClassName Win32_PnPSignedDriver
        Export-Object $signed $out (Join-Path $Script:CsvPath "Drivers_PnPSigned.csv")

        if ($signed) {
            Append-Text $out "`r`n=== UNSIGNED OR UNKNOWN SIGNATURE DRIVERS ==="
            $unsigned = $signed | Where-Object {
                ($_.IsSigned -eq $false) -or
                ($_.Signer -eq $null) -or
                ($_.Signer -eq "")
            }

            $Script:Metrics.UnsignedDriverCount = ($unsigned | Measure-Object).Count
            $unsigned | Select-Object DeviceName, Manufacturer, DriverVersion, DriverDate, IsSigned, Signer, InfName |
                Format-Table -AutoSize | Out-String -Width 4096 | Out-File $out -Append -Encoding UTF8
            $unsigned | Export-Csv -Path (Join-Path $Script:CsvPath "Drivers_Unsigned_Unknown.csv") -Encoding UTF8 -NoTypeInformation

            if ($Script:Metrics.UnsignedDriverCount -gt 0) {
                Add-Finding "WARN" "Drivers" "Обнаружены неподписанные или неизвестно подписанные драйверы: $($Script:Metrics.UnsignedDriverCount)." "Проверить драйверы, особенно сетевые, дисковые, антивирусные и старые устройства."
            }

            Append-Text $out "`r`n=== OLD DRIVERS OLDER THAN 5 YEARS ==="
            $limit = (Get-Date).AddYears(-5)
            $oldDrivers = @()
            foreach ($d in $signed) {
                try {
                    if ($d.DriverDate) {
                        $dt = [System.Management.ManagementDateTimeConverter]::ToDateTime($d.DriverDate)
                        if ($dt -lt $limit) {
                            $oldDrivers += New-Object PSObject -Property @{
                                DeviceName = $d.DeviceName
                                Manufacturer = $d.Manufacturer
                                DriverVersion = $d.DriverVersion
                                DriverDate = $dt
                                IsSigned = $d.IsSigned
                                Signer = $d.Signer
                                InfName = $d.InfName
                            }
                        }
                    }
                }
                catch {
                }
            }

            $oldDrivers | Sort-Object DriverDate | Format-Table -AutoSize | Out-String -Width 4096 | Out-File $out -Append -Encoding UTF8
            $oldDrivers | Export-Csv -Path (Join-Path $Script:CsvPath "Drivers_Older_Than_5_Years.csv") -Encoding UTF8 -NoTypeInformation
        }

        Append-Text $out "`r`n=== DRIVERQUERY ==="
        Invoke-CommandSafe -FilePath "cmd.exe" -Arguments "/c driverquery /v /fo csv" -OutputFile (Join-Path $Script:ReportsPath "08A_DriverQuery.csv.txt") -TimeoutSeconds 300

        Append-Text $out "`r`n=== PNP DEVICES WITH ERROR ==="
        $pnp = Get-CimSafe -ClassName Win32_PnPEntity
        if ($pnp) {
            $badPnp = $pnp | Where-Object { $_.ConfigManagerErrorCode -ne 0 }
            $badPnp | Select-Object Name, Manufacturer, PNPDeviceID, ConfigManagerErrorCode, Status |
                Format-Table -AutoSize | Out-String -Width 4096 | Out-File $out -Append -Encoding UTF8
            $badPnp | Export-Csv -Path (Join-Path $Script:CsvPath "PNP_Devices_With_Errors.csv") -Encoding UTF8 -NoTypeInformation

            if (($badPnp | Measure-Object).Count -gt 0) {
                Add-Finding "WARN" "Devices" "Есть устройства с ошибками в диспетчере устройств: $(($badPnp | Measure-Object).Count)." "Открыть Диспетчер устройств и проверить устройства с ошибками."
            }
        }
    }
    catch {
        Write-Log "Collect-Drivers failed: $($_.Exception.Message)" "ERROR"
    }
}

function Collect-WindowsEvents {
    Write-Host "Collecting Windows event logs..."

    $out = Join-Path $Script:ReportsPath "09_Windows_Events.txt"

    try {
        $logs = @("System", "Application", "Security")

        foreach ($log in $logs) {
            try {
                Append-Text $out "`r`n=== LOG: $log LAST 1000 ==="
                $events = Get-WinEvent -LogName $log -MaxEvents 1000 -ErrorAction Stop
                $events | Select-Object TimeCreated, Id, LevelDisplayName, ProviderName, Message |
                    Format-List * | Out-File -FilePath $out -Encoding UTF8 -Append -Width 4096
                $events | Select-Object TimeCreated, Id, LevelDisplayName, ProviderName, Message |
                    Export-Csv -Path (Join-Path $Script:CsvPath ("Events_{0}.csv" -f $log)) -Encoding UTF8 -NoTypeInformation
            }
            catch {
                Append-Text $out "Cannot read log $log : $($_.Exception.Message)"
                Write-Log "Cannot read event log $log : $($_.Exception.Message)" "ERROR"
            }
        }

        $providerChecks = @(
            @{ Name = "Kernel-Power"; Provider = "Microsoft-Windows-Kernel-Power"; Log = "System"; Csv = "Events_KernelPower.csv" },
            @{ Name = "Disk"; Provider = "disk"; Log = "System"; Csv = "Events_Disk.csv" },
            @{ Name = "Ntfs"; Provider = "Ntfs"; Log = "System"; Csv = "Events_Ntfs.csv" },
            @{ Name = "WHEA"; Provider = "Microsoft-Windows-WHEA-Logger"; Log = "System"; Csv = "Events_WHEA.csv" },
            @{ Name = "BugCheck"; Provider = "Microsoft-Windows-WER-SystemErrorReporting"; Log = "System"; Csv = "Events_BugCheck.csv" }
        )

        foreach ($check in $providerChecks) {
            try {
                Append-Text $out "`r`n=== PROVIDER: $($check.Name) LAST 1000 ==="
                $events = Get-WinEvent -FilterHashtable @{ LogName = $check.Log; ProviderName = $check.Provider } -MaxEvents 1000 -ErrorAction Stop
                $events | Select-Object TimeCreated, Id, LevelDisplayName, ProviderName, Message |
                    Format-List * | Out-File -FilePath $out -Encoding UTF8 -Append -Width 4096
                $events | Select-Object TimeCreated, Id, LevelDisplayName, ProviderName, Message |
                    Export-Csv -Path (Join-Path $Script:CsvPath $check.Csv) -Encoding UTF8 -NoTypeInformation

                $criticalOrError = ($events | Where-Object { $_.LevelDisplayName -match "Critical|Error|Критический|Ошибка" } | Measure-Object).Count

                switch ($check.Name) {
                    "Kernel-Power" {
                        $Script:Metrics.KernelPowerCount = ($events | Measure-Object).Count
                        if ($Script:Metrics.KernelPowerCount -gt 0) {
                            Add-Finding "WARN" "Kernel-Power" "Найдены события Kernel-Power: $($Script:Metrics.KernelPowerCount)." "Проверить резкие выключения, питание, батарею, блок питания, перегрев."
                        }
                    }
                    "Disk" {
                        $Script:Metrics.DiskErrorCount += $criticalOrError
                    }
                    "Ntfs" {
                        $Script:Metrics.NtfsErrorCount += $criticalOrError
                    }
                    "WHEA" {
                        $Script:Metrics.WheaCount = ($events | Measure-Object).Count
                        if ($Script:Metrics.WheaCount -gt 0) {
                            Add-Finding "CRITICAL" "WHEA" "Найдены аппаратные WHEA-события: $($Script:Metrics.WheaCount)." "Проверить CPU/RAM/диск/питание/перегрев. WHEA часто указывает на аппаратную проблему."
                        }
                    }
                    "BugCheck" {
                        $Script:Metrics.BugCheckCount = ($events | Measure-Object).Count
                        if ($Script:Metrics.BugCheckCount -gt 0) {
                            Add-Finding "CRITICAL" "BugCheck" "Найдены события синих экранов/bugcheck: $($Script:Metrics.BugCheckCount)." "Проверить дампы памяти, драйверы и аппаратные ошибки."
                        }
                    }
                }
            }
            catch {
                Append-Text $out "Provider $($check.Name) unavailable or no events: $($_.Exception.Message)"
            }
        }
    }
    catch {
        Write-Log "Collect-WindowsEvents failed: $($_.Exception.Message)" "ERROR"
    }
}

