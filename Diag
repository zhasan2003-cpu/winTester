function Collect-InstalledPrograms {
    Write-Host "Collecting installed programs..."

    $out = Join-Path $Script:ReportsPath "11_Installed_Programs.txt"

    try {
        $programs = @()
        $regPaths = @(
            "HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\*",
            "HKLM:\Software\Wow6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*",
            "HKCU:\Software\Microsoft\Windows\CurrentVersion\Uninstall\*"
        )

        foreach ($path in $regPaths) {
            try {
                $items = Get-ItemProperty -Path $path -ErrorAction SilentlyContinue
                foreach ($item in $items) {
                    if ($item.DisplayName) {
                        $programs += New-Object PSObject -Property @{
                            Name = $item.DisplayName
                            Version = $item.DisplayVersion
                            InstallDate = $item.InstallDate
                            Publisher = $item.Publisher
                            InstallLocation = $item.InstallLocation
                            UninstallString = $item.UninstallString
                            RegistryPath = $path
                        }
                    }
                }
            }
            catch {
                Write-Log "Installed programs registry path failed $path : $($_.Exception.Message)" "ERROR"
            }
        }

        $programs = $programs | Sort-Object Name -Unique
        $programs | Export-Csv -Path (Join-Path $Script:CsvPath "Installed_Programs.csv") -Encoding UTF8 -NoTypeInformation
        $programs | Format-Table Name, Version, InstallDate, Publisher -AutoSize |
            Out-String -Width 4096 | Out-File -FilePath $out -Encoding UTF8

        $pupPatterns = @(
            "MediaGet",
            "Zona",
            "Amigo",
            "Mail.Ru",
            "Sputnik",
            "uTorrent",
            "Torrent",
            "DriverPack",
            "IObit",
            "Advanced SystemCare",
            "Auslogics",
            "Baidu",
            "Tencent",
            "360 Total",
            "Web Companion",
            "RelevantKnowledge",
            "PremierOpinion",
            "OfferCore",
            "CCleaner"
        )

        $possiblePup = @()
        foreach ($p in $programs) {
            foreach ($pattern in $pupPatterns) {
                if ($p.Name -match [regex]::Escape($pattern)) {
                    $possiblePup += $p
                }
            }
        }

        if (($possiblePup | Measure-Object).Count -gt 0) {
            $Script:Metrics.SuspiciousPrograms = $possiblePup | Select-Object -ExpandProperty Name -Unique
            Append-Text $out "`r`n=== POSSIBLE UNWANTED / PERFORMANCE-AFFECTING SOFTWARE ==="
            $possiblePup | Format-Table Name, Version, Publisher -AutoSize | Out-String -Width 4096 | Out-File $out -Append -Encoding UTF8
            Add-Finding "INFO" "Software" "Найдены программы, которые могут влиять на производительность или быть нежелательными: $($Script:Metrics.SuspiciousPrograms -join ', ')." "Проверить, нужны ли эти программы. Не удалять корпоративное ПО без согласования."
        }
    }
    catch {
        Write-Log "Collect-InstalledPrograms failed: $($_.Exception.Message)" "ERROR"
    }
}

function Collect-Temperatures {
    Write-Host "Collecting temperatures..."

    $out = Join-Path $Script:ReportsPath "12_Temperatures.txt"

    try {
        Append-Text $out "=== ACPI THERMAL ZONES ==="
        $thermal = Get-CimSafe -Namespace "root\wmi" -ClassName MSAcpi_ThermalZoneTemperature
        if ($thermal) {
            $thermalResults = @()
            foreach ($t in $thermal) {
                try {
                    $celsius = [math]::Round(($t.CurrentTemperature / 10) - 273.15, 2)
                    $thermalResults += New-Object PSObject -Property @{
                        InstanceName = $t.InstanceName
                        TemperatureC = $celsius
                        RawCurrentTemperature = $t.CurrentTemperature
                    }

                    if ($celsius -gt 85) {
                        Add-Finding "WARN" "Temperature" "ACPI температура высокая: $celsius C, $($t.InstanceName)." "Проверить охлаждение, пыль, термопасту, вентилятор."
                    }
                }
                catch {
                }
            }
            $thermalResults | Format-Table -AutoSize | Out-String -Width 4096 | Out-File $out -Encoding UTF8 -Append
            $thermalResults | Export-Csv -Path (Join-Path $Script:CsvPath "Temperatures_ACPI.csv") -Encoding UTF8 -NoTypeInformation
        }
        else {
            Append-Text $out "ACPI thermal data unavailable."
        }

        Append-Text $out "`r`n=== DISK TEMPERATURE FROM SMART ATTRIBUTE 194 / 190 IF AVAILABLE ==="
        $smartData = Get-CimSafe -Namespace "root\wmi" -ClassName MSStorageDriver_FailurePredictData
        $temps = @()
        if ($smartData) {
            foreach ($d in $smartData) {
                $attrs = Decode-SmartAttributes -VendorSpecific $d.VendorSpecific
                foreach ($a in $attrs) {
                    if ($a.ID -eq 194 -or $a.ID -eq 190) {
                        $tempValue = $a.Raw -band 0xFF
                        $temps += New-Object PSObject -Property @{
                            InstanceName = $d.InstanceName
                            AttributeID = $a.ID
                            AttributeName = $a.Name
                            TemperatureC = $tempValue
                            Raw = $a.Raw
                        }

                        if ($tempValue -gt 50) {
                            Add-Finding "WARN" "Disk Temperature" "Температура накопителя высокая: $tempValue C, $($d.InstanceName)." "Проверить охлаждение. Для HDD желательно держать ниже 45-50 C."
                        }
                    }
                }
            }
        }

        if ($temps.Count -gt 0) {
            $temps | Format-Table -AutoSize | Out-String -Width 4096 | Out-File $out -Append -Encoding UTF8
            $temps | Export-Csv -Path (Join-Path $Script:CsvPath "Temperatures_Disk_SMART.csv") -Encoding UTF8 -NoTypeInformation
        }
        else {
            Append-Text $out "SMART temperature attributes unavailable."
        }

        Append-Text $out "`r`n=== NOTE ==="
        Append-Text $out "CPU/GPU temperature is not consistently exposed by Windows built-in tools on all systems. If firmware/WMI exposes sensors, ACPI values above are collected. No third-party sensor drivers were used."
    }
    catch {
        Write-Log "Collect-Temperatures failed: $($_.Exception.Message)" "ERROR"
    }
}

function Run-SystemChecks {
    Write-Host "Running system checks. This can take time..."

    $out = Join-Path $Script:ReportsPath "13_System_Checks.txt"

    try {
        Append-Text $out "=== SFC VERIFYONLY ==="
        Invoke-CommandSafe -FilePath "sfc.exe" -Arguments "/verifyonly" -OutputFile $out -TimeoutSeconds 3600

        Append-Text $out "`r`n=== DISM SCANHEALTH ==="
        Invoke-CommandSafe -FilePath "dism.exe" -Arguments "/Online /Cleanup-Image /ScanHealth" -OutputFile $out -TimeoutSeconds 3600

        Append-Text $out "`r`n=== POWERSHELL REPAIR COMMANDS AVAILABILITY ==="
        try {
            Get-Command Repair-WindowsImage -ErrorAction Stop | Format-List * | Out-File $out -Append -Encoding UTF8 -Width 4096
        }
        catch {
            Append-Text $out "Repair-WindowsImage not available or module not loaded."
        }

        Append-Text $out "`r`n=== POWERCFG ENERGY 60 SECONDS ==="
        $energyHtml = Join-Path $Script:RootPath "powercfg_energy.html"
        Invoke-CommandSafe -FilePath "powercfg.exe" -Arguments "/energy /duration 60 /output `"$energyHtml`"" -OutputFile $out -TimeoutSeconds 180

        Append-Text $out "`r`n=== POWERCFG BATTERY REPORT IF SUPPORTED ==="
        $batteryHtml = Join-Path $Script:RootPath "battery_report.html"
        Invoke-CommandSafe -FilePath "powercfg.exe" -Arguments "/batteryreport /output `"$batteryHtml`"" -OutputFile $out -TimeoutSeconds 120

        Append-Text $out "`r`n=== WINSAT CPU ==="
        Invoke-CommandSafe -FilePath "winsat.exe" -Arguments "cpuformal" -OutputFile $out -TimeoutSeconds 1200

        Append-Text $out "`r`n=== WINSAT MEMORY ==="
        Invoke-CommandSafe -FilePath "winsat.exe" -Arguments "mem" -OutputFile $out -TimeoutSeconds 1200

        Append-Text $out "`r`n=== WINSAT FEATURES ==="
        Invoke-CommandSafe -FilePath "winsat.exe" -Arguments "features" -OutputFile $out -TimeoutSeconds 600
    }
    catch {
        Write-Log "Run-SystemChecks failed: $($_.Exception.Message)" "ERROR"
    }
}

function Collect-SecurityAndMalwareIndicators {
    Write-Host "Collecting security indicators..."

    $out = Join-Path $Script:ReportsPath "14_Security_Indicators.txt"

    try {
        Append-Text $out "=== WINDOWS DEFENDER STATUS ==="
        try {
            $mp = Get-MpComputerStatus -ErrorAction Stop
            Export-Object $mp $out (Join-Path $Script:CsvPath "Defender_Status.csv")
        }
        catch {
            Append-Text $out "Get-MpComputerStatus unavailable: $($_.Exception.Message)"
        }

        Append-Text $out "`r`n=== LOCAL USERS ==="
        try {
            $users = Get-LocalUser -ErrorAction Stop
            $users | Export-Csv -Path (Join-Path $Script:CsvPath "Local_Users.csv") -Encoding UTF8 -NoTypeInformation
            $users | Format-Table -AutoSize | Out-String -Width 4096 | Out-File $out -Append -Encoding UTF8
        }
        catch {
            Append-Text $out "Get-LocalUser unavailable. Using net user."
            Invoke-CommandSafe -FilePath "cmd.exe" -Arguments "/c net user" -OutputFile $out -TimeoutSeconds 120
        }

        Append-Text $out "`r`n=== LOCAL ADMINISTRATORS ==="
