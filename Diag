}

function Generate-Summary {
    Write-Host "Generating summary..."

    try {
        $end = Get-Date
        $duration = New-TimeSpan -Start $Script:StartTime -End $end

        Append-Text $Script:SummaryFile "PC DIAGNOSTICS SUMMARY"
        Append-Text $Script:SummaryFile "Generated: $end"
        Append-Text $Script:SummaryFile "Duration: $($duration.ToString())"
        Append-Text $Script:SummaryFile "Computer: $env:COMPUTERNAME"
        Append-Text $Script:SummaryFile "User: $env:USERNAME"
        Append-Text $Script:SummaryFile "Root folder: $Script:RootPath"
        Append-Text $Script:SummaryFile ""

        Append-Text $Script:SummaryFile "=== QUICK METRICS ==="
        Append-Text $Script:SummaryFile ("Average CPU 60s: {0}%" -f $Script:Metrics.AvgCpu)
        Append-Text $Script:SummaryFile ("Max CPU 60s: {0}%" -f $Script:Metrics.MaxCpu)
        Append-Text $Script:SummaryFile ("Average Available RAM 60s: {0} MB" -f $Script:Metrics.AvgAvailableMemoryMB)
        Append-Text $Script:SummaryFile ("Minimum Available RAM 60s: {0} MB" -f $Script:Metrics.MinAvailableMemoryMB)
        Append-Text $Script:SummaryFile ("Average Disk Queue 60s: {0}" -f $Script:Metrics.AvgDiskQueue)
        Append-Text $Script:SummaryFile ("Max Disk Queue 60s: {0}" -f $Script:Metrics.MaxDiskQueue)
        Append-Text $Script:SummaryFile ("Average Disk Read MB/s 60s: {0}" -f $Script:Metrics.AvgDiskReadMBs)
        Append-Text $Script:SummaryFile ("Average Disk Write MB/s 60s: {0}" -f $Script:Metrics.AvgDiskWriteMBs)
        Append-Text $Script:SummaryFile ("Disk error count: {0}" -f $Script:Metrics.DiskErrorCount)
        Append-Text $Script:SummaryFile ("NTFS error count: {0}" -f $Script:Metrics.NtfsErrorCount)
        Append-Text $Script:SummaryFile ("Kernel-Power events: {0}" -f $Script:Metrics.KernelPowerCount)
        Append-Text $Script:SummaryFile ("WHEA events: {0}" -f $Script:Metrics.WheaCount)
        Append-Text $Script:SummaryFile ("BugCheck events: {0}" -f $Script:Metrics.BugCheckCount)
        Append-Text $Script:SummaryFile ("Unsigned drivers: {0}" -f $Script:Metrics.UnsignedDriverCount)
        Append-Text $Script:SummaryFile ("Startup items collected: {0}" -f $Script:Metrics.StartupCount)
        Append-Text $Script:SummaryFile ("SMART warnings: {0}" -f $Script:Metrics.SmartWarningCount)
        Append-Text $Script:SummaryFile ""

        if ($Script:Metrics.SmartWarningCount -gt 0) {
            Add-Finding "CRITICAL" "Storage" "Обнаружены SMART-признаки проблем накопителя." "Сделать резервную копию и рассмотреть замену диска, особенно если это HDD."
        }

        if ($Script:Metrics.DiskErrorCount -gt 0) {
            Add-Finding "CRITICAL" "Storage" "Обнаружены ошибки Disk в журналах Windows." "Проверить SMART, выполнить backup, проверить кабели/контакты, заменить диск при повторении ошибок."
        }

        if ($Script:Metrics.NtfsErrorCount -gt 0) {
            Add-Finding "WARN" "File System" "Обнаружены ошибки NTFS." "Проверить файловую систему chkdsk и состояние накопителя."
        }

        if ($Script:Findings.Count -eq 0) {
            Add-Finding "OK" "General" "Критичных проблем автоматически не обнаружено." "Открыть отчеты вручную для детального анализа."
        }

        Append-Text $Script:SummaryFile "=== AUTOMATIC FINDINGS ==="
        $ordered = $Script:Findings | Sort-Object @{
            Expression = {
                switch ($_.Severity) {
                    "CRITICAL" { 1 }
                    "WARN" { 2 }
                    "INFO" { 3 }
                    "OK" { 4 }
                    default { 5 }
                }
            }
        }, Category

        foreach ($f in $ordered) {
            Append-Text $Script:SummaryFile ("[{0}] {1}: {2}" -f $f.Severity, $f.Category, $f.Message)
            Append-Text $Script:SummaryFile ("Recommendation: {0}" -f $f.Recommendation)
            Append-Text $Script:SummaryFile ""
        }

        Append-Text $Script:SummaryFile "=== WHAT TO SEND FOR ANALYSIS ==="
        Append-Text $Script:SummaryFile "Send the generated ZIP archive to the engineer or upload it to ChatGPT."
        Append-Text $Script:SummaryFile "Most useful files:"
        Append-Text $Script:SummaryFile "1. SUMMARY.txt"
        Append-Text $Script:SummaryFile "2. Reports\02_Disks.txt"
        Append-Text $Script:SummaryFile "3. CSV\SMART_Attributes.csv"
        Append-Text $Script:SummaryFile "4. CSV\Performance_60s.csv"
        Append-Text $Script:SummaryFile "5. Reports\09_Windows_Events.txt"
        Append-Text $Script:SummaryFile "6. Reports\05_Processes.txt"
        Append-Text $Script:SummaryFile ""
        Append-Text $Script:SummaryFile "=== LIMITATIONS ==="
        Append-Text $Script:SummaryFile "Only built-in Windows tools were used."
        Append-Text $Script:SummaryFile "Some temperature sensors may be unavailable without vendor drivers."
        Append-Text $Script:SummaryFile "Full per-process open-file enumeration is not reliably available on all Windows versions without third-party tools."
    }
    catch {
        Write-Log "Generate-Summary failed: $($_.Exception.Message)" "ERROR"
    }
}

function Create-ZipArchive {
    Write-Host "Creating ZIP archive..."

    try {
        if (Test-Path $Script:ZipPath) {
            Remove-Item $Script:ZipPath -Force -ErrorAction SilentlyContinue
        }

        try {
            Compress-Archive -Path (Join-Path $Script:RootPath "*") -DestinationPath $Script:ZipPath -Force -ErrorAction Stop
        }
        catch {
            Write-Log "Compress-Archive failed, trying .NET ZipFile: $($_.Exception.Message)" "WARN"
            Add-Type -AssemblyName System.IO.Compression.FileSystem
            [System.IO.Compression.ZipFile]::CreateFromDirectory($Script:RootPath, $Script:ZipPath)
        }

        Append-Text $Script:SummaryFile ""
        Append-Text $Script:SummaryFile "ZIP archive: $Script:ZipPath"
    }
    catch {
        Write-Log "Create-ZipArchive failed: $($_.Exception.Message)" "ERROR"
    }
}

