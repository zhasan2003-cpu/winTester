    $out = Join-Path $Script:ReportsPath "07_Services.txt"

    try {
        $services = Get-CimSafe -ClassName Win32_Service

        Append-Text $out "=== ALL SERVICES ==="
        Export-Object $services $out (Join-Path $Script:CsvPath "Services_All.csv")

        if ($services) {
            Append-Text $out "`r`n=== RUNNING SERVICES ==="
            $running = $services | Where-Object { $_.State -eq "Running" }
            $running | Select-Object Name, DisplayName, State, StartMode, StartName, PathName |
                Format-Table -AutoSize | Out-String -Width 4096 | Out-File $out -Append -Encoding UTF8
            $running | Export-Csv -Path (Join-Path $Script:CsvPath "Services_Running.csv") -Encoding UTF8 -NoTypeInformation

            Append-Text $out "`r`n=== DISABLED SERVICES ==="
